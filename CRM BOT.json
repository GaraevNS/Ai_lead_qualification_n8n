      "parameters": {
        "jsCode": "// Берём строку из поля output\nconst raw = $input.first().json.output;\n\n// Если это строка, парсим её в объект\nlet inputData;\n\ntry {\n    inputData = typeof raw === \"string\" ? JSON.parse(raw) : raw;\n} catch (e) {\n    throw new Error(\"Не удалось распарсить JSON: \" + e.message);\n}\n\n// Формируем новый объект с нужными полями\nconst outputData = {\n    \"Name\": inputData.name || \"\",\n    \"Email\": inputData.email || \"\",\n    \"Company\": inputData.company || \"\",\n    \"Budget\": inputData.budget || \"\",\n    \"Message\": inputData.message || \"\",\n    \"AI Score\": inputData.ai_score || \"\",\n    \"AI Status\": inputData.ai_status || \"\",\n    \"AI Summary\": inputData.ai_summary || \"\"\n};\n\n// Возвращаем как массив объектов\nreturn [{\n    json: outputData\n}];"
      },
